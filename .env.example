# Astro Consul – environment configuration
# Copy to .env and adjust as needed.

# Application
ASTRO_CONSUL_APP_NAME=Astro Consul
ASTRO_CONSUL_ENV=development

# API
ASTRO_CONSUL_API_V1_PREFIX=/api/v1

# Persistence: "file" (default, JSON on disk) or "database"
ASTRO_CONSUL_PERSISTENCE_BACKEND=file

# Database (only used when PERSISTENCE_BACKEND=database)
# ASTRO_CONSUL_DATABASE_URL=postgresql://user:pass@localhost:5432/astro_consul
ASTRO_CONSUL_LOCAL_DATABASE_URL=sqlite:///./astro_consul.db

# CORS – comma-separated origins (leave empty to disable)
# ASTRO_CONSUL_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: redirect the www host to the apex domain, e.g. big3.me
# ASTRO_CONSUL_CANONICAL_HOST=big3.me

# Optional: Sentry DSN for error tracking
# ASTRO_CONSUL_SENTRY_DSN=https://...@sentry.io/...

# Default local-dev user (file backend only)
ASTRO_CONSUL_DEFAULT_USER_ID=user_local_dev
ASTRO_CONSUL_DEFAULT_AUTH_SUBJECT=local-dev
ASTRO_CONSUL_DEFAULT_USER_EMAIL=local@example.com
